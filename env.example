# MindFold3D Environment Variables
# Copy this to .env and update with your values

# Security — REQUIRED. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Never commit your real value. Rotating invalidates all existing login sessions.
SECRET_KEY=change-me-generate-with-secrets-token_urlsafe-64

# Database — SQLAlchemy connection URL. Optional; defaults to SQLite below.
#   SQLite (zero-setup, single file):
#     DATABASE_URL=sqlite:///./mindfold.db
#   PostgreSQL:
#     DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname
# On Replit, DATABASE_URL is typically injected automatically (Postgres);
# leave this unset locally to use SQLite.
DATABASE_URL=sqlite:///./mindfold.db

# Token settings
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LLM Coaching — uses any OpenAI-compatible endpoint.
# Set all three of LLM_BASE_URL, LLM_MODEL, and LLM_API_KEY for cloud providers.
# Leave them at the local defaults below to use a local Ollama / LM Studio / vLLM
# instance. Leave LLM_API_KEY unset (or "not-needed") for local setups.
#
# Examples:
#   OpenAI:  LLM_BASE_URL=https://api.openai.com/v1
#            LLM_MODEL=gpt-4o-mini    # verify current model IDs at platform.openai.com/docs/models
#            LLM_API_KEY=sk-...
#   Groq:    LLM_BASE_URL=https://api.groq.com/openai/v1
#            LLM_MODEL=llama-3.1-70b-versatile
#            LLM_API_KEY=gsk-...
#   Local:   LLM_BASE_URL=http://localhost:11434/v1   (Ollama default)
#            LLM_MODEL=llama3.1:8b
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1:8b
LLM_TIMEOUT=30
LLM_MAX_TOKENS=512
# LLM_API_KEY=not-needed

